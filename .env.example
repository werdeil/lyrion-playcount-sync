# Configuration Docker pour Lyrion Playcount Sync
# Copier ce fichier en .env et adapter les valeurs

# ===== VNC Configuration =====
# Mot de passe pour l'accès VNC
VNC_PASSWORD=changeme

# Port VNC direct (défaut: 5900)
VNC_PORT=5900

# Port noVNC (accès web) (défaut: 6080)
NOVNC_PORT=6080

# Dimensions de l'écran virtuel
VNC_WIDTH=1280
VNC_HEIGHT=1024
VNC_DEPTH=24

# ===== Lyrion Data =====
# Chemin vers la base de données Lyrion sur l'hôte
# IMPORTANT: Adapter ce chemin selon votre installation!
# 
# Exemples:
#   Linux Squeezebox: /var/lib/squeezeboxserver/prefs
#   macOS: ~/Library/Application Support/Squeezebox/prefs
#   Windows: C:\Users\<username>\AppData\Local\Squeezebox\prefs
#   Synology: /volume1/docker/squeezebox-lms/prefs
#
LYRION_DATA_PATH=/path/to/lyrion/config

# ===== Timezone =====
# Fuseau horaire du conteneur
TZ=Europe/Paris

# ===== Traefik Configuration =====
# À utiliser si vous avez Traefik en reverse proxy
# TRAEFIK_NETWORK=homelab
# LYRION_SYNC_HOST=lyrion-sync.local

# Seuil de similarité pour le matching (0-100)
SIMILARITY_THRESHOLD=85

# Méthode de matching: ratio, partial_ratio, token_sort_ratio, token_set_ratio
MATCHING_METHOD=token_sort_ratio

# Direction de synchronisation: from_tracks, from_alternative, merge
SYNC_DIRECTION=merge

# Appliquer automatiquement (true/false)
AUTO_APPLY=false

# Créer une sauvegarde avant sync (true/false)
BACKUP_BEFORE_SYNC=true
